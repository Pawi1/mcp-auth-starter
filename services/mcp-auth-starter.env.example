# cp services/mcp-auth-starter.env.example /etc/mcp-auth-starter/mcp-auth-starter.env
# chmod 600 /etc/mcp-auth-starter/mcp-auth-starter.env

# JWT signing secret — generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-python-secrets-token-hex-32

# Config file path (default: directory of the binary)
MCP_CONFIG_PATH=/etc/mcp-auth-starter/config.json
